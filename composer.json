{
    "name": "groupesti/laravel-ca-csr",
    "description": "CSR management for Laravel CA",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "groupesti/laravel-ca": "^0.1",
        "groupesti/laravel-ca-key": "^0.1",
        "phpseclib/phpseclib": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CA\\Csr\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CA\\Csr\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CA\\Csr\\CsrServiceProvider"
            ],
            "aliases": {
                "CaCsr": "CA\\Csr\\Facades\\CaCsr"
            }
        }
    }
}
